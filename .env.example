# Runtime profile
#SPRING_PROFILES_ACTIVE=prod
spring.profiles.active=prod

# App ports
APP_PORT=8080
SERVER_PORT=8080
MYSQL_PORT=3306
# Local IDE/CLI run target (host machine MySQL)
DB_HOST=127.0.0.1
# Docker compose app container target (service DNS inside compose network)
DB_HOST_DOCKER=mysql
DB_PORT=3306

# MySQL container credentials
MYSQL_DATABASE=quantitymeasurement
MYSQL_USER=quantity_app
MYSQL_PASSWORD=change-me-mysql-user-password
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password

# Spring JPA behavior for prod profile
DB_DDL_AUTO=update


# Security
JWT_SECRET=replace-with-a-strong-256-bit-secret
JWT_EXPIRATION=86400000

# OAuth2 (Google)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# Frontend origins allowed by backend CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
